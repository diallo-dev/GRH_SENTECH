<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GRH SENTECH</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        body { background-color: #f8f9fa; }
        .sidebar { min-height: 100vh; background: linear-gradient(135deg, #1e3a5f 0%, #2d6a9f 100%); padding-top: 20px; }
        .sidebar a { color: #cde4ff; padding: 12px 20px; display: block; text-decoration: none; border-radius: 5px; margin: 2px 8px; transition: all 0.2s; }
        .sidebar a:hover { background-color: rgba(255,255,255,0.15); color: white; }
        .sidebar .sidebar-brand { color: white; font-size: 1.2rem; font-weight: bold; text-align: center; padding: 15px; border-bottom: 1px solid rgba(255,255,255,0.2); margin-bottom: 10px; }
        .main-content { padding: 25px; }
        .card { box-shadow: 0 2px 8px rgba(0,0,0,0.08); border: none; }
        .card-header { background: #1e3a5f; color: white; font-weight: 600; }
        .table th { background-color: #f1f4f8; font-weight: 600; }
    </style>
</head>
<body>
<div class="container-fluid">
  <div class="row">
    <div class="col-md-2 sidebar px-0">
      <div class="sidebar-brand"><i class="fas fa-building"></i> GRH SENTECH</div>
      <nav>
        <a asp-controller="Home" asp-action="Index"><i class="fas fa-tachometer-alt mr-2"></i> Dashboard</a>
        <a asp-controller="Employe" asp-action="Index"><i class="fas fa-users mr-2"></i> Employés</a>
        <a asp-controller="Departement" asp-action="Index"><i class="fas fa-sitemap mr-2"></i> Départements</a>
        <a href="#"><i class="fas fa-file-contract mr-2"></i> Contrats</a>
        <a href="#"><i class="fas fa-star mr-2"></i> Évaluations</a>
        <a href="#"><i class="fas fa-calendar-alt mr-2"></i> Congés</a>
      </nav>
    </div>
    <div class="col-md-10 main-content">
      @if (TempData["Success"] != null) {
        <div class="alert alert-success alert-dismissible fade show">
          <i class="fas fa-check-circle mr-2"></i>@TempData["Success"]
          <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
        </div>
      }
      @if (TempData["Error"] != null) {
        <div class="alert alert-danger alert-dismissible fade show">
          <i class="fas fa-exclamation-circle mr-2"></i>@TempData["Error"]
          <button type="button" class="close" data-dismiss="alert"><span>&times;</span></button>
        </div>
      }
      @RenderBody()
    </div>
  </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.4.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validate/1.19.5/jquery.validate.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-validation-unobtrusive/3.2.12/jquery.validate.unobtrusive.min.js"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
