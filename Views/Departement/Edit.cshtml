@model GRH_SENTECH.ViewModels.DepartementViewModel
@{
    ViewData["Title"] = "Modifier Département";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-edit mr-2 text-warning"></i>Modifier : @Model.Nom</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left mr-1"></i> Retour</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-header"><i class="fas fa-sitemap mr-2"></i> Modification du département</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Nom" class="font-weight-bold"></label>
                <input asp-for="Nom" class="form-control" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Code" class="font-weight-bold"></label>
                <input asp-for="Code" class="form-control" maxlength="6"
                       style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()" />
                <span asp-validation-for="Code" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Budget" class="font-weight-bold"></label>
                <div class="input-group">
                    <input asp-for="Budget" class="form-control" type="number" min="0" step="100000" />
                    <div class="input-group-append">
                        <span class="input-group-text">FCFA</span>
                    </div>
                </div>
                <span asp-validation-for="Budget" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <div class="custom-control custom-switch">
                    <input asp-for="IsActif" class="custom-control-input" type="checkbox" id="isActif" />
                    <label class="custom-control-label" for="isActif">Département actif</label>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary mr-2">Annuler</a>
                <button type="submit" class="btn btn-warning">
                    <i class="fas fa-save mr-1"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
