@model GRH_SENTECH.ViewModels.DepartementViewModel
@{
    ViewData["Title"] = "Nouveau Département";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-plus-circle mr-2 text-primary"></i>Nouveau Département</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left mr-1"></i> Retour</a>
</div>

<div class="card" style="max-width:600px;">
    <div class="card-header"><i class="fas fa-sitemap mr-2"></i> Informations du département</div>
    <div class="card-body">
        <form asp-action="Create" method="post">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="form-group">
                <label asp-for="Nom" class="font-weight-bold"></label>
                <input asp-for="Nom" class="form-control" placeholder="Ex: Informatique" />
                <span asp-validation-for="Nom" class="text-danger small"></span>
            </div>

            <div class="form-group">
                <label asp-for="Code" class="font-weight-bold"></label>
                <input asp-for="Code" class="form-control" placeholder="Ex: INFO" maxlength="6"
                       style="text-transform:uppercase;" oninput="this.value=this.value.toUpperCase()" />
                <span asp-validation-for="Code" class="text-danger small"></span>
                <small class="text-muted">3 à 6 caractères, unique</small>
            </div>

            <div class="form-group">
                <label asp-for="Budget" class="font-weight-bold"></label>
                <div class="input-group">
                    <input asp-for="Budget" class="form-control" type="number" min="0" step="100000" />
                    <div class="input-group-append">
                        <span class="input-group-text">FCFA</span>
                    </div>
                </div>
                <span asp-validation-for="Budget" class="text-danger small"></span>
            </div>

            <hr />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary mr-2">Annuler</a>
                <button type="submit" class="btn btn-primary">
                    <i class="fas fa-save mr-1"></i> Enregistrer
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
