@model IEnumerable<GRH_SENTECH.ViewModels.DepartementViewModel>
@{
    ViewData["Title"] = "Départements";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-sitemap mr-2 text-primary"></i>Gestion des Départements</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="fas fa-plus mr-1"></i> Nouveau Département
    </a>
</div>

<div class="row">
    @foreach (var dept in Model)
    {
        <div class="col-md-4 mb-4">
            <div class="card h-100">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span>
                        <span class="badge badge-light text-dark mr-2">@dept.Code</span>
                        @dept.Nom
                    </span>
                    @if (dept.IsActif)
                    { <span class="badge badge-success">Actif</span> }
                    else
                    { <span class="badge badge-secondary">Inactif</span> }
                </div>
                <div class="card-body">
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small"><i class="fas fa-users mr-1"></i> Employés</span>
                        <strong>@dept.NombreEmployes</strong>
                    </div>
                    <div class="d-flex justify-content-between mb-2">
                        <span class="text-muted small"><i class="fas fa-wallet mr-1"></i> Budget</span>
                        <strong>@dept.Budget.ToString("N0") FCFA</strong>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted small"><i class="fas fa-calendar mr-1"></i> Créé le</span>
                        <span>@dept.DateCreation.ToString("dd/MM/yyyy")</span>
                    </div>

                    <!-- Barre de progression budget utilisé -->
                    @{
                        var pct = dept.Budget > 0 ? (int)Math.Min(100, dept.TotalSalaires / dept.Budget * 100) : 0;
                    }
                    <div class="mt-3">
                        <small class="text-muted">Utilisation du budget : @pct%</small>
                        <div class="progress mt-1" style="height:6px;">
                            <div class="progress-bar @(pct > 90 ? "bg-danger" : pct > 70 ? "bg-warning" : "bg-success")"
                                 style="width:@pct%"></div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-white d-flex justify-content-end">
                    <a asp-action="Edit" asp-route-id="@dept.Id" class="btn btn-sm btn-warning mr-2">
                        <i class="fas fa-edit"></i> Modifier
                    </a>
                    <form asp-action="Delete" method="post" class="d-inline"
                          onsubmit="return confirm('Supprimer ce département ?')">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="id" value="@dept.Id" />
                        <button type="submit" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    }
</div>

@if (!Model.Any())
{
    <div class="text-center text-muted py-5">
        <i class="fas fa-inbox fa-3x mb-3 d-block"></i>
        Aucun département trouvé.
        <div class="mt-3">
            <a asp-action="Create" class="btn btn-primary">
                <i class="fas fa-plus mr-1"></i> Créer le premier département
            </a>
        </div>
    </div>
}
