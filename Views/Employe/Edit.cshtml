@model GRH_SENTECH.ViewModels.EmployeViewModel
@{
    ViewData["Title"] = "Modifier l'Employé";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-edit mr-2 text-warning"></i>Modifier : @Model.NomComplet</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left mr-1"></i> Retour</a>
</div>

<div class="card">
    <div class="card-header"><i class="fas fa-edit mr-2"></i> Modification de l'employé</div>
    <div class="card-body">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Matricule" class="font-weight-bold"></label>
                        <input asp-for="Matricule" class="form-control" />
                        <span asp-validation-for="Matricule" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="DepartementId" class="font-weight-bold"></label>
                        <select asp-for="DepartementId" asp-items="Model.Departements" class="form-control">
                            <option value="">-- Sélectionner --</option>
                        </select>
                        <span asp-validation-for="DepartementId" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Nom" class="font-weight-bold"></label>
                        <input asp-for="Nom" class="form-control" />
                        <span asp-validation-for="Nom" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Prenom" class="font-weight-bold"></label>
                        <input asp-for="Prenom" class="form-control" />
                        <span asp-validation-for="Prenom" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Email" class="font-weight-bold"></label>
                        <input asp-for="Email" class="form-control" type="email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="Genre" class="font-weight-bold"></label>
                        <select asp-for="Genre" class="form-control"
                                asp-items="Html.GetEnumSelectList<GRH_SENTECH.Entity.Genre>()"></select>
                    </div>
                </div>
            </div>

            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="DateNaissance" class="font-weight-bold"></label>
                        <input asp-for="DateNaissance" class="form-control" type="date" />
                        <span asp-validation-for="DateNaissance" class="text-danger small"></span>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label asp-for="DateEmbauche" class="font-weight-bold"></label>
                        <input asp-for="DateEmbauche" class="form-control" type="date" />
                        <span asp-validation-for="DateEmbauche" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary mr-2"><i class="fas fa-times mr-1"></i> Annuler</a>
                <button type="submit" class="btn btn-warning"><i class="fas fa-save mr-1"></i> Enregistrer les modifications</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
