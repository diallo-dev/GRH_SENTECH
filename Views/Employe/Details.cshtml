@model GRH_SENTECH.ViewModels.EmployeViewModel
@{
    ViewData["Title"] = "Détails Employé";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user mr-2 text-info"></i>@Model.NomComplet</h2>
    <div>
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning mr-2">
            <i class="fas fa-edit mr-1"></i> Modifier
        </a>
        <a asp-action="AjouterContrat" asp-route-id="@Model.Id" class="btn btn-success mr-2">
            <i class="fas fa-file-contract mr-1"></i> Ajouter Contrat
        </a>
        <a asp-action="Index" class="btn btn-outline-secondary">
            <i class="fas fa-arrow-left mr-1"></i> Retour
        </a>
    </div>
</div>

<div class="row">
    <!-- Infos personnelles -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-id-card mr-2"></i> Informations personnelles</div>
            <div class="card-body">
                <table class="table table-borderless table-sm">
                    <tr>
                        <td class="font-weight-bold text-muted" width="40%">Matricule</td>
                        <td><strong>@Model.Matricule</strong></td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Nom complet</td>
                        <td>@Model.NomComplet</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Email</td>
                        <td>@Model.Email</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Genre</td>
                        <td>@Model.Genre</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Date de naissance</td>
                        <td>@Model.DateNaissance.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Date d'embauche</td>
                        <td>@Model.DateEmbauche.ToString("dd/MM/yyyy")</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Département</td>
                        <td>@Model.DepartementNom</td>
                    </tr>
                    <tr>
                        <td class="font-weight-bold text-muted">Statut</td>
                        <td>
                            @if (Model.IsActif)
                            {
                                <span class="badge badge-success">Actif</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Inactif</span>
                            }
                        </td>
                    </tr>
                </table>
            </div>
        </div>
    </div>

    <!-- Contrat actuel -->
    <div class="col-md-6 mb-4">
        <div class="card h-100">
            <div class="card-header"><i class="fas fa-file-contract mr-2"></i> Contrat actuel</div>
            <div class="card-body">
                @if (Model.ContratActifType != null)
                {
                    <table class="table table-borderless table-sm">
                        <tr>
                            <td class="font-weight-bold text-muted" width="40%">Type</td>
                            <td>
                                @if (Model.ContratActifType == "CDI")
                                { <span class="badge badge-success badge-pill">CDI</span> }
                                else if (Model.ContratActifType == "CDD")
                                { <span class="badge badge-warning badge-pill text-dark">CDD</span> }
                                else if (Model.ContratActifType == "Stage")
                                { <span class="badge badge-info badge-pill">Stage</span> }
                                else
                                { <span class="badge badge-secondary badge-pill">@Model.ContratActifType</span> }
                            </td>
                        </tr>
                        <tr>
                            <td class="font-weight-bold text-muted">Poste</td>
                            <td>@Model.PosteActuel</td>
                        </tr>
                        <tr>
                            <td class="font-weight-bold text-muted">Salaire de base</td>
                            <td><strong>@Model.SalaireActuel?.ToString("N0") FCFA</strong></td>
                        </tr>
                    </table>
                }
                else
                {
                    <div class="text-center py-3 text-muted">
                        <i class="fas fa-exclamation-triangle fa-2x mb-2 d-block text-warning"></i>
                        Aucun contrat actif
                        <div class="mt-3">
                            <a asp-action="AjouterContrat" asp-route-id="@Model.Id" class="btn btn-sm btn-success">
                                <i class="fas fa-plus mr-1"></i> Ajouter un contrat
                            </a>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
