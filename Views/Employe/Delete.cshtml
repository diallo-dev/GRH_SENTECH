@model GRH_SENTECH.ViewModels.EmployeViewModel
@{
    ViewData["Title"] = "Supprimer Employé";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2><i class="fas fa-user-times mr-2 text-danger"></i>Supprimer un Employé</h2>
    <a asp-action="Index" class="btn btn-outline-secondary"><i class="fas fa-arrow-left mr-1"></i> Retour</a>
</div>

<div class="card border-danger">
    <div class="card-header bg-danger text-white">
        <i class="fas fa-exclamation-triangle mr-2"></i> Confirmation de suppression
    </div>
    <div class="card-body">
        <div class="alert alert-warning">
            <strong><i class="fas fa-info-circle mr-1"></i> Attention :</strong>
            Cette action désactivera l'employé. Elle est irréversible si l'employé a un contrat CDI actif ou des congés en attente (RG03).
        </div>

        <table class="table table-borderless table-sm">
            <tr>
                <td class="font-weight-bold text-muted" width="30%">Matricule</td>
                <td>@Model.Matricule</td>
            </tr>
            <tr>
                <td class="font-weight-bold text-muted">Nom complet</td>
                <td><strong>@Model.NomComplet</strong></td>
            </tr>
            <tr>
                <td class="font-weight-bold text-muted">Email</td>
                <td>@Model.Email</td>
            </tr>
            <tr>
                <td class="font-weight-bold text-muted">Département</td>
                <td>@Model.DepartementNom</td>
            </tr>
            <tr>
                <td class="font-weight-bold text-muted">Contrat actif</td>
                <td>
                    @if (Model.ContratActifType != null)
                    {
                        <span class="badge badge-@(Model.ContratActifType == "CDI" ? "success" : "warning")">
                            @Model.ContratActifType
                        </span>
                    }
                    else { <span class="text-muted">Aucun</span> }
                </td>
            </tr>
        </table>

        <hr />
        <form asp-action="Delete" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="id" value="@Model.Id" />
            <div class="d-flex justify-content-end">
                <a asp-action="Index" class="btn btn-outline-secondary mr-2">
                    <i class="fas fa-times mr-1"></i> Annuler
                </a>
                <button type="submit" class="btn btn-danger">
                    <i class="fas fa-trash mr-1"></i> Confirmer la suppression
                </button>
            </div>
        </form>
    </div>
</div>
